# EmailDeliveryHero backend — copy to .env for local development.
# Secrets can also live out-of-repo in ~/.credentials/email_delivery_hero.json (env vars win).

NODE_ENV=development
PORT=9312

# The Vite frontend origin(s) allowed to call this API (comma-separated). Required.
CORS_ORIGINS=http://localhost:9311

# Company Google Workspace domains allowed to sign in (comma-separated).
AUTH_ALLOWED_DOMAINS=whitehatengineering.com,act3ai.com

# Google OAuth client — or put these under email_delivery_hero.google in the credentials file.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI defaults to <frontend-origin>/api/v1/oauth_callback

# Auth cookie namespace for THIS app (avoids clobbering other localhost apps' cookies).
AUTH_COOKIE_PREFIX=oaf_edh

# Periodic re-audits: minutes between automatic runs of every domain (0 or unset = disabled).
EDH_PERIODIC_AUDIT_MINUTES=0

# Where the app persists its state (domains, audits, session store). Defaults to ~/.email_delivery_hero
# EDH_STATE_DIR=
