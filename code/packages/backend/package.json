{
  "name": "@edh/backend",
  "version": "0.1.0",
  "private": true,
  "description": "EmailDeliveryHero back-end — NestJS REST API with Swagger; auth via OpenAuthFederated (@auth/backend, an externally-linked open-source library).",
  "main": "dist/main.js",
  "bin": {
    "edh": "dist/cli.js"
  },
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "cli": "node dist/cli.js",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@auth/backend": "link:../../../../OpenAuthFederated/code/packages/auth-backend",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "8.1.0",
    "passport": "0.7.0",
    "passport-custom": "^1.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.ts$": "ts-jest" },
    "moduleNameMapper": {
      "^@config/(.*)$": "<rootDir>/config/$1",
      "^@module/(.*)$": "<rootDir>/modules/$1",
      "^@shared/(.*)$": "<rootDir>/shared/$1"
    },
    "setupFiles": [
      "<rootDir>/../test/jest-setup-env.ts"
    ],
    "testEnvironment": "node"
  }
}
