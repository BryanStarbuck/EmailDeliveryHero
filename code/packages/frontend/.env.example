# EmailDeliveryHero frontend — copy to .env.local for local development.
# In dev, Vite proxies /api to the backend (see vite.config.ts), so these usually stay as defaults.

# Base for API calls and the embedded OpenAuthFederated Frontend API (the SDK appends /v1).
VITE_API_BASE=/api
VITE_AUTH_FRONTEND_API=/api

# Company Google Workspace domains allowed to sign in.
VITE_AUTH_ALLOWED_DOMAINS=whitehatengineering.com,act3ai.com

# Optional OpenAuthFederated publishable key (if your deployment uses one).
# VITE_AUTH_PUBLISHABLE_KEY=
